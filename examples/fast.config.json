{
    "project_id": "fast-vllm-project",
    "project_name": "Fast Performance Project",
    "runtime_version": "1.0.0",
    "config_version": "1.0.0",
    "directories": {
        "cache_dir": "cache",
        "log_dir": "logs",
        "output_dir": "outputs"
    },
    "logging": {
        "level": "WARNING",
        "console": true,
        "file": true
    },
    "inference": {
        "enabled_backends": ["vllm"],
        "default_backend": "vllm"
    },
    "performance": {
        "mode": "fast",
        "gpu_memory_utilization": 0.70,
        "context_limit": 2048,
        "precision": "float16",
        "quantization": "awq"
    }
}
