{
    "project_id": "high-quality-project",
    "project_name": "High Quality Project",
    "runtime_version": "1.0.0",
    "config_version": "1.0.0",
    "directories": {
        "cache_dir": "cache",
        "log_dir": "logs",
        "output_dir": "outputs"
    },
    "logging": {
        "level": "INFO",
        "console": true,
        "file": true
    },
    "inference": {
        "enabled_backends": ["transformers"],
        "default_backend": "transformers"
    },
    "performance": {
        "mode": "quality",
        "gpu_memory_utilization": 0.95,
        "context_limit": 8192,
        "precision": "bfloat16",
        "quantization": "none"
    }
}
